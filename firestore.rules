rules_version = '2';

// Firestore Security Rules for the HI-NOVA APEX LLP website.
//
// Model:
//  - blog_posts         : public READ; WRITE only by admin.
//  - contacts           : public CREATE; READ/UPDATE only by admin.
//  - newsletter /
//    newsletter_subscribers : public CREATE; READ only by admin.
//  - team_members       : public READ; WRITE only by admin.
//  - services           : public READ; WRITE only by admin.
//  - projects           : public READ; WRITE only by admin.
//  - testimonials       : public READ; WRITE only by admin.
//
// "Admin" = a signed-in Firebase Auth user whose email is in the allow-list
// below. Update ADMIN_EMAILS to match the account(s) you created in
// Firebase Console -> Authentication (Email/Password provider).
//
// Deploy:  firebase deploy --only firestore:rules
// or paste into Firebase Console -> Firestore Database -> Rules -> Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email in [
               'admin@hinovaapex.com',
               'admin@hinova.com'
             ];
    }

    function validContact() {
      return request.resource.data.email is string
          && request.resource.data.email.size() > 3
          && request.resource.data.email.size() <= 254
          && request.resource.data.message.size() <= 5000;
    }

    function validNewsletter() {
      return request.resource.data.email is string
          && request.resource.data.email.size() > 3
          && request.resource.data.email.size() <= 254;
    }

    // Blog posts
    match /blog_posts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Contact form submissions
    match /contacts/{docId} {
      allow create: if validContact();
      allow read, update, delete: if isAdmin();
    }

    // Newsletter signups (both collection names supported for backward compat).
    match /newsletter/{docId} {
      allow create: if validNewsletter();
      allow read, update, delete: if isAdmin();
    }
    match /newsletter_subscribers/{docId} {
      allow create: if validNewsletter();
      allow read, update, delete: if isAdmin();
    }

    // ─── Phase E CMS collections (public read, admin write) ────────────
    match /team_members/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /services/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /projects/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
